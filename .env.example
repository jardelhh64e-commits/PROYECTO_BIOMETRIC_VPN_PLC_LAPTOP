# ================================================================
#  PLANTILLA DE VARIABLES DE ENTORNO
# ================================================================
# Este archivo SÍ se sube al repositorio como referencia.
# Para usar el sistema:
#   1. Copiar este archivo como ".env"  (mismo directorio)
#   2. Reemplazar cada valor con tu credencial real
#   3. El archivo .env quedará ignorado por git (ver .gitignore)
# ================================================================

# Clave pre-compartida HMAC-SHA256 entre laptop y Raspberry Pi.
# Debe ser idéntica en ambos lados. No debe viajar por la red.
HMAC_KEY=PON_TU_CLAVE_PRECOMPARTIDA_AQUI

# IP y puerto del gateway de la Raspberry Pi sobre la red ZeroTier.
ZEROTIER_HOST=10.x.x.x
ZEROTIER_PORT=8088
